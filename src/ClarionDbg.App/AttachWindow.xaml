<Window x:Class="ClarionDbg.App.AttachWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Attach to Process" Height="460" Width="680" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource Panel}" Foreground="{StaticResource Fg}" FontFamily="Segoe UI">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Pick a running process to attach to" FontWeight="SemiBold"
                   FontSize="15" Margin="0,0,0,8"/>
        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Content="Refresh" Width="80" Click="Refresh_Click"/>
            <CheckBox x:Name="ChkClarionOnly" Content="Only processes with Clarion debug info"
                      IsChecked="True" Foreground="{StaticResource Fg}" VerticalAlignment="Center"
                      Click="Refresh_Click"/>
        </DockPanel>
        <DataGrid x:Name="Grid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  Background="Transparent" Foreground="{StaticResource Fg}" BorderBrush="{StaticResource Border}"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource Border}"
                  RowBackground="Transparent" AlternatingRowBackground="#FF2A2A2D"
                  HeadersVisibility="Column" FontFamily="Consolas" FontSize="12"
                  SelectionMode="Single" MouseDoubleClick="Grid_DoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="70"/>
                <DataGridTextColumn Header="Process" Binding="{Binding Name}" Width="160"/>
                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Attach" Width="90" Click="Attach_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="90" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="ClarionDbg.App.ArrayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Array" Height="480" Width="560" WindowStartupLocation="CenterOwner"
        Background="{StaticResource Panel}" Foreground="{StaticResource Fg}" FontFamily="Segoe UI">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TxtHeader" Grid.Row="0" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
        <DataGrid x:Name="Grid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  Background="Transparent" Foreground="{StaticResource Fg}" BorderBrush="{StaticResource Border}"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource Border}"
                  RowBackground="Transparent" AlternatingRowBackground="#FF2A2A2D"
                  HeadersVisibility="Column" FontFamily="Consolas" FontSize="12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Index" Binding="{Binding Index}" Width="70"/>
                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="100"/>
                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
